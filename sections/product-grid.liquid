{%- liquid
  assign collection = collections[section.settings.collection]
  assign limit = section.settings.products_to_show
  assign columns = section.settings.columns
-%}

<section class="section scheme-{{ section.settings.color_scheme }}">
  <div class="page-width" style="--grid-cols: {{ columns }};">
    <div class="product-grid__head reveal">
      <div>
        {%- if section.settings.overline != blank -%}
          <span class="overline index-mark" data-index="{{ section.settings.index_number }}">{{ section.settings.overline }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a
          href="{{ section.settings.button_link | default: collection.url | default: routes.all_products_collection_url }}"
          class="link"
        >{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>

    <div class="product-grid__items">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: limit -%}
          <div class="reveal" style="--reveal-delay: {{ forloop.index0 | times: 0.06 }}s;">
            {% render 'product-card', product: product %}
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Kuratierte Default-Karten mit mitgelieferten Motiven {%- endcomment -%}
        {%- assign demo_titles = 'Solitär-Ring Lumen|Siegelring Atlas|Ohrhänger Goutte|Verlobungsring Aurum' | split: '|' -%}
        {%- assign demo_prices = 'ab 690 €|540 €|390 €|ab 1.290 €' | split: '|' -%}
        {%- assign demo_images = 'klunker-solitaire.png|klunker-signet.png|klunker-earring.png|klunker-ring.png' | split: '|' -%}
        {%- assign demo_badges = 'Neu||Neu|' | split: '|' -%}
        {%- for i in (0..3) -%}
          {%- if forloop.index > limit -%}{%- break -%}{%- endif -%}
          <div class="reveal" style="--reveal-delay: {{ i | times: 0.06 }}s;">
            {% render 'product-card',
              image_asset: demo_images[i],
              title: demo_titles[i],
              price: demo_prices[i],
              vendor: '18 Karat Gold',
              badge: demo_badges[i] %}
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Produkt-Grid",
  "tag": "section",
  "class": "section-product-grid",
  "settings": [
    {
      "type": "header",
      "content": "Überschrift"
    },
    {
      "type": "text",
      "id": "index_number",
      "label": "Nummer (z. B. 01)",
      "default": "01"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "Die Kollektion"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Neuheiten"
    },
    {
      "type": "header",
      "content": "Produkte"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion",
      "info": "Ohne Kollektion werden kuratierte Beispielkarten angezeigt."
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Anzahl Produkte",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Spalten (Desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Link-Text",
      "default": "Alle ansehen"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link",
      "info": "Leer lassen, um auf die gewählte Kollektion zu verlinken."
    },
    {
      "type": "header",
      "content": "Darstellung"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Farbschema",
      "options": [
        { "value": "white", "label": "Reinweiß" },
        { "value": "offwhite", "label": "Off-White" },
        { "value": "black", "label": "Tiefschwarz" }
      ],
      "default": "white"
    }
  ],
  "presets": [
    {
      "name": "Produkt-Grid"
    }
  ]
}
{% endschema %}
