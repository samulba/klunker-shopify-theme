{%- liquid
  assign collection = collections[section.settings.collection]
  assign limit = section.settings.products_to_show
  assign columns = section.settings.columns
-%}

<section class="section scheme-{{ section.settings.color_scheme }}">
  <div class="page-width" style="--grid-cols: {{ columns }};">
    {%- if section.settings.heading != blank or section.settings.overline != blank -%}
      <div class="product-grid__head">
        {%- if section.settings.overline != blank -%}
          <span class="overline">{{ section.settings.overline }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="h2">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <p class="text-muted">{{ section.settings.text }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="product-grid__items">
      {%- if collection != blank and collection.products_count > 0 -%}
        {%- for product in collection.products limit: limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- comment -%} Platzhalter, solange noch keine Produkte/Kollektion verknüpft sind {%- endcomment -%}
        {%- for i in (1..limit) -%}
          {% render 'product-card', placeholder: true %}
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.button_label != blank -%}
      <div class="product-grid__foot">
        <a
          href="{{ section.settings.button_link | default: collection.url | default: routes.all_products_collection_url }}"
          class="btn{% if section.settings.button_style == 'solid' %} btn--solid{% endif %}"
        >
          {{ section.settings.button_label }}
        </a>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Produkt-Grid",
  "tag": "section",
  "class": "section-product-grid",
  "settings": [
    {
      "type": "header",
      "content": "Überschrift"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "Die Kollektion"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Neuheiten"
    },
    {
      "type": "text",
      "id": "text",
      "label": "Untertext",
      "default": "Ausgewählte Stücke der aktuellen Saison."
    },
    {
      "type": "header",
      "content": "Produkte"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Kollektion"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "label": "Anzahl Produkte",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Spalten (Desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Alle ansehen"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link",
      "info": "Leer lassen, um auf die gewählte Kollektion zu verlinken."
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button-Stil",
      "options": [
        { "value": "outline", "label": "Outline" },
        { "value": "solid", "label": "Fläche" }
      ],
      "default": "outline"
    },
    {
      "type": "header",
      "content": "Darstellung"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Farbschema",
      "options": [
        { "value": "white", "label": "Reinweiß" },
        { "value": "offwhite", "label": "Off-White" },
        { "value": "black", "label": "Tiefschwarz" }
      ],
      "default": "white"
    }
  ],
  "presets": [
    {
      "name": "Produkt-Grid"
    }
  ]
}
{% endschema %}
