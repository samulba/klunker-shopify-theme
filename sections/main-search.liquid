<section class="section">
  <div class="page-width" style="--grid-cols: {{ section.settings.columns }};">
    <div class="page-header">
      <span class="overline">{{ 'general.search.search' | t }}</span>
      <h1 class="h1">{{ 'general.search.search' | t }}</h1>
    </div>

    <form action="{{ routes.search_url }}" method="get" role="search" class="search-form">
      <input
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.placeholder' | t }}"
        aria-label="{{ 'general.search.search' | t }}"
      >
      <button type="submit" class="btn">{{ 'general.search.search' | t }}</button>
    </form>

    {%- if search.performed -%}
      {%- if search.results_count > 0 -%}
        <p class="text-muted text-center" style="margin-bottom: var(--space-xl);">
          {{ 'general.search.results_with_count' | t: count: search.results_count }}
        </p>
        <div class="product-grid__items">
          {%- for item in search.results -%}
            {%- if item.object_type == 'product' -%}
              {% render 'product-card', product: item %}
            {%- else -%}
              <a href="{{ item.url }}" class="product-card">
                <span class="product-card__title">{{ item.title }}</span>
              </a>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- else -%}
        <p class="placeholder-note">{{ 'general.search.no_results' | t: terms: search.terms }}</p>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

<style>
  .search-form {
    display: flex;
    gap: var(--space-sm);
    max-width: 38rem;
    margin: 0 auto var(--space-2xl);
  }
  .search-form input {
    flex: 1;
    border: 0;
    border-bottom: 1px solid var(--color-hairline-strong);
    background: transparent;
    font: inherit;
    font-size: 1.1rem;
    padding: 0.6rem 0;
  }
  .search-form input:focus {
    outline: none;
    border-color: var(--color-text);
  }
</style>

{% schema %}
{
  "name": "Suche",
  "tag": "section",
  "settings": [
    {
      "type": "range",
      "id": "columns",
      "label": "Spalten (Desktop)",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    }
  ]
}
{% endschema %}
