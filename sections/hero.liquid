{%- liquid
  assign has_image = false
  if section.settings.image != blank
    assign has_image = true
  endif
-%}

<section
  class="hero{% if has_image %} hero--on-image{% endif %} scheme-{{ section.settings.color_scheme }}"
  style="--hero-height: {{ section.settings.height }}vh; --hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
>
  <div class="hero__media">
    {%- if has_image -%}
      {{
        section.settings.image
        | image_url: width: 3000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '600, 900, 1200, 1600, 2000, 2600, 3000',
          alt: section.settings.heading
      }}
      <div class="hero__overlay"></div>
    {%- endif -%}
  </div>

  <div class="hero__inner page-width">
    <div class="hero__content{% if section.settings.text_alignment == 'center' %} hero__content--center{% endif %}">
      {%- if section.settings.overline != blank -%}
        <span class="overline">{{ section.settings.overline }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero__title">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="hero__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank or section.settings.button_label_2 != blank -%}
        <div class="hero__actions">
          {%- if section.settings.button_label != blank -%}
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="btn{% if section.settings.button_style == 'solid' %} btn--solid{% endif %}"
            >
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_label_2 != blank -%}
            <a href="{{ section.settings.button_link_2 | default: '#' }}" class="btn btn--ghost">
              {{ section.settings.button_label_2 }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow / Kollektion",
      "default": "Frühjahr / Sommer 2026"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Die Kunst der Zurückhaltung"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Reduzierte Silhouetten, edle Materialien, zeitlose Eleganz. Eine Garderobe, die leise spricht.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button 1 – Text",
      "default": "Kollektion entdecken"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button 1 – Link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button 1 – Stil",
      "options": [
        { "value": "outline", "label": "Outline" },
        { "value": "solid", "label": "Fläche" }
      ],
      "default": "outline"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 – Text",
      "default": "Lookbook"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 – Link"
    },
    {
      "type": "header",
      "content": "Bild & Darstellung"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hintergrundbild",
      "info": "Großzügiges Editorial-Bild. Ohne Bild wird die Off-White-Fläche verwendet."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bild-Abdunkelung",
      "min": 0,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 15
    },
    {
      "type": "range",
      "id": "height",
      "label": "Höhe",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 85
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Textausrichtung",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Farbschema (ohne Bild)",
      "options": [
        { "value": "white", "label": "Reinweiß" },
        { "value": "offwhite", "label": "Off-White" },
        { "value": "black", "label": "Tiefschwarz" }
      ],
      "default": "offwhite"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
