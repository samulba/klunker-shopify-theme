<section
  class="hero hero--on-image scheme-{{ section.settings.color_scheme }}"
  style="--hero-height: {{ section.settings.height }}vh; --hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"
>
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 3000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '600, 900, 1200, 1600, 2000, 2600, 3000',
          alt: section.settings.heading
      }}
    {%- else -%}
      <img
        src="{{ 'klunker-ring-dark.png' | asset_url }}"
        alt="{{ section.settings.heading | escape }}"
        loading="eager"
        fetchpriority="high"
        width="1672"
        height="941"
      >
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>

  <div class="hero__inner page-width">
    <div class="hero__content hero__content--{{ section.settings.text_alignment }} reveal">
      {%- if section.settings.overline != blank -%}
        <span class="overline">{{ section.settings.overline }}</span>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="hero__title hero__title--animated">
          {%- assign hero_words = section.settings.heading | split: ' ' -%}
          {%- for word in hero_words -%}
            <span class="word"><span style="--i: {{ forloop.index0 }}">{{ word }}</span></span>
            {% endfor -%}
        </h1>
      {%- endif -%}

      {%- if section.settings.text != blank -%}
        <div class="hero__text">{{ section.settings.text }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank or section.settings.button_label_2 != blank -%}
        <div class="hero__actions">
          {%- if section.settings.button_label != blank -%}
            <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--solid">
              {{ section.settings.button_label }}
            </a>
          {%- endif -%}
          {%- if section.settings.button_label_2 != blank -%}
            <a href="{{ section.settings.button_link_2 | default: '#' }}" class="btn">
              {{ section.settings.button_label_2 }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_scroll_cue -%}
    <span class="hero__scroll">{{ section.settings.scroll_label }}</span>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero",
  "tag": "section",
  "class": "section-hero",
  "settings": [
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "Custom Feinschmuck · Berlin"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Alles, was du willst — in Gold."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Custom-Schmuck auf Anfrage. Für alle, vom Siegelring bis zum Solitär — nach deinem Entwurf von Hand gefertigt.</p>"
    },
    {
      "type": "header",
      "content": "Buttons"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button 1 – Text",
      "default": "Custom anfragen"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button 1 – Link"
    },
    {
      "type": "text",
      "id": "button_label_2",
      "label": "Button 2 – Text",
      "default": "Kollektion ansehen"
    },
    {
      "type": "url",
      "id": "button_link_2",
      "label": "Button 2 – Link"
    },
    {
      "type": "header",
      "content": "Bild & Darstellung"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hintergrundbild",
      "info": "Ohne Bild wird das mitgelieferte Hero-Motiv (Diamant-Ring) verwendet."
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bild-Abdunkelung",
      "min": 0,
      "max": 70,
      "step": 5,
      "unit": "%",
      "default": 28
    },
    {
      "type": "range",
      "id": "height",
      "label": "Höhe",
      "min": 60,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Textausrichtung",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" }
      ],
      "default": "center"
    },
    {
      "type": "checkbox",
      "id": "show_scroll_cue",
      "label": "Scroll-Hinweis anzeigen",
      "default": true
    },
    {
      "type": "text",
      "id": "scroll_label",
      "label": "Scroll-Text",
      "default": "Scrollen"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Farbschema (Fallback)",
      "options": [
        { "value": "white", "label": "Reinweiß" },
        { "value": "offwhite", "label": "Off-White" },
        { "value": "black", "label": "Tiefschwarz" }
      ],
      "default": "offwhite"
    }
  ],
  "presets": [
    {
      "name": "Hero"
    }
  ]
}
{% endschema %}
