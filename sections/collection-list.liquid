<section class="section scheme-{{ section.settings.color_scheme }}">
  <div class="page-width" style="--tile-cols: {{ section.blocks.size | at_most: 4 }};">
    {%- if section.settings.heading != blank or section.settings.link_label != blank -%}
      <div class="tiles__head reveal">
        <div>
          {%- if section.settings.overline != blank -%}
            <span class="overline">{{ section.settings.overline }}</span>
          {%- endif -%}
          {%- if section.settings.heading != blank -%}
            <h2 class="h2" style="margin-top: var(--space-2xs);">{{ section.settings.heading }}</h2>
          {%- endif -%}
        </div>
        {%- if section.settings.link_label != blank -%}
          <a href="{{ section.settings.link_url | default: '#' }}" class="link">{{ section.settings.link_label }}</a>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tiles">
      {%- for block in section.blocks -%}
        {%- liquid
          assign fallback = ''
          case forloop.index0
            when 0
              assign fallback = 'klunker-ring.png'
            when 1
              assign fallback = 'klunker-portrait.png'
            when 2
              assign fallback = 'klunker-earring.png'
            when 3
              assign fallback = 'klunker-bangles.png'
          endcase
          assign has_visual = false
          if block.settings.image != blank or fallback != blank
            assign has_visual = true
          endif
        -%}
        <a
          href="{{ block.settings.link | default: '#' }}"
          class="tile reveal{% unless has_visual %} tile--placeholder{% endunless %}"
          style="--reveal-delay: {{ forloop.index0 | times: 0.08 }}s;"
          {{ block.shopify_attributes }}
        >
          {% render 'responsive-image',
            image: block.settings.image,
            fallback: fallback,
            alt: block.settings.title,
            loading: 'lazy' %}
          <div class="tile__scrim"></div>
          <div class="tile__body">
            <span class="tile__title">{{ block.settings.title }}</span>
            <span class="tile__cta">{{ block.settings.cta | default: 'Ansehen' }}</span>
          </div>
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Kategorien",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "Entdecken"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Nach Kategorie"
    },
    {
      "type": "text",
      "id": "link_label",
      "label": "Link-Text (rechts)",
      "default": "Alle Stücke"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Farbschema",
      "options": [
        { "value": "white", "label": "Reinweiß" },
        { "value": "offwhite", "label": "Off-White" },
        { "value": "black", "label": "Tiefschwarz" }
      ],
      "default": "white"
    }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Kachel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild",
          "info": "Ohne Bild wird ein passendes mitgeliefertes Motiv verwendet."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Ringe"
        },
        {
          "type": "text",
          "id": "cta",
          "label": "Hinweis",
          "default": "Ansehen"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Kategorien",
      "blocks": [
        { "type": "tile", "settings": { "title": "Ringe", "cta": "Ansehen" } },
        { "type": "tile", "settings": { "title": "Halsketten", "cta": "Ansehen" } },
        { "type": "tile", "settings": { "title": "Ohrringe", "cta": "Ansehen" } }
      ]
    }
  ]
}
{% endschema %}
