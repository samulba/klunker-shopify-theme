<section class="scrolly scheme-black" data-scrolly style="--chapters: {{ section.blocks.size }};">
  <div class="scrolly__sticky">
    {%- comment -%} Bildebenen (überblenden je Kapitel) {%- endcomment -%}
    <div class="scrolly__media">
      {%- for block in section.blocks -%}
        {%- liquid
          assign n = forloop.index
          assign fallback = 'klunker-sk' | append: n | append: '.png'
        -%}
        <div class="scrolly__layer{% if forloop.first %} is-active{% endif %}" data-ch="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {% render 'responsive-image',
            image: block.settings.image,
            fallback: fallback,
            alt: block.settings.heading,
            loading: 'lazy' %}
        </div>
      {%- endfor -%}
    </div>

    <div class="scrolly__scrim"></div>

    <div class="scrolly__ui page-width">
      <div class="scrolly__top">
        {%- if section.settings.overline != blank -%}
          <span class="overline">{{ section.settings.overline }}</span>
        {%- endif -%}
        <span class="scrolly__counter">
          <b data-scrolly-index>01</b><span>/ {{ section.blocks.size | prepend: '0' }}</span>
        </span>
      </div>

      <div class="scrolly__captions">
        {%- for block in section.blocks -%}
          <div class="scrolly__caption{% if forloop.first %} is-active{% endif %}" data-ch="{{ forloop.index0 }}">
            <span class="scrolly__num">{{ forloop.index | prepend: '0' }}</span>
            {%- if block.settings.heading != blank -%}
              <h2 class="scrolly__title">{{ block.settings.heading }}</h2>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <p class="scrolly__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>

      <div class="scrolly__progress"><span data-scrolly-bar></span></div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Scrollytelling",
  "tag": "section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "paragraph",
      "content": "Gepinnte Bildstrecke: Beim Scrollen wechseln Bild und Text Kapitel für Kapitel. Ohne eigenes Bild werden die mitgelieferten Atelier-Motive (sk1–sk4) verwendet."
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "Vom Entwurf zum Unikat"
    }
  ],
  "blocks": [
    {
      "type": "chapter",
      "name": "Kapitel",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Überschrift",
          "default": "Die Idee"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Alles beginnt mit einer Skizze."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Scrollytelling",
      "blocks": [
        { "type": "chapter", "settings": { "heading": "Die Idee", "text": "Alles beginnt mit einer Skizze — deiner Idee, von Hand zu Papier gebracht." } },
        { "type": "chapter", "settings": { "heading": "Der Stein", "text": "Jeder Diamant wird einzeln ausgewählt und unter der Lupe geprüft." } },
        { "type": "chapter", "settings": { "heading": "Das Handwerk", "text": "An der Werkbank entsteht aus massivem Gold dein Stück — in reiner Handarbeit." } },
        { "type": "chapter", "settings": { "heading": "Dein Unikat", "text": "Ein Schmuckstück, das es nur ein einziges Mal gibt. Deins." } }
      ]
    }
  ]
}
{% endschema %}
