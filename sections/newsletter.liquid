<section class="section scheme-{{ section.settings.color_scheme }}">
  <div class="page-width page-width--narrow">
    <div class="cta-band reveal">
      {%- if section.settings.overline != blank -%}
        <span class="overline">{{ section.settings.overline }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="h2 cta-band__title">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="cta-band__text">{{ section.settings.text }}</p>
      {%- endif -%}

      {%- form 'customer', class: 'newsletter' -%}
        {%- if form.posted_successfully? -%}
          <p class="cta-band__text">{{ 'general.newsletter.success' | t }}</p>
        {%- else -%}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <input
            type="email"
            name="contact[email]"
            placeholder="{{ section.settings.placeholder | escape }}"
            aria-label="{{ section.settings.placeholder | escape }}"
            required
          >
          <button type="submit">{{ 'general.newsletter.subscribe' | t }}</button>
        {%- endif -%}
      {%- endform -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "Letters von Klunker"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Als Erste:r erfahren."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Text",
      "default": "Neue Stücke, limitierte Editionen und Einblicke ins Atelier — direkt in Ihr Postfach."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Platzhalter",
      "default": "E-Mail-Adresse"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Farbschema",
      "options": [
        { "value": "white", "label": "Reinweiß" },
        { "value": "offwhite", "label": "Off-White" },
        { "value": "black", "label": "Tiefschwarz" }
      ],
      "default": "black"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
