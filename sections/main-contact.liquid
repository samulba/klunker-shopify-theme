<section class="section">
  <div class="page-width page-width--narrow">
    <div class="page-header">
      {%- if section.settings.overline != blank -%}
        <span class="overline">{{ section.settings.overline }}</span>
      {%- endif -%}
      <h1 class="h1">{{ section.settings.heading | default: page.title }}</h1>
      {%- if section.settings.intro != blank -%}
        <p class="lede" style="max-width: 46ch; margin: var(--space-sm) auto 0;">{{ section.settings.intro }}</p>
      {%- endif -%}
    </div>

    {%- if page.content != blank -%}
      <div class="rte" style="margin-bottom: var(--space-xl);">{{ page.content }}</div>
    {%- endif -%}

    {%- form 'contact', class: 'contact-form' -%}
      {%- if form.posted_successfully? -%}
        <p class="contact-success">{{ section.settings.success_message }}</p>
      {%- else -%}
        {%- if form.errors -%}
          <div class="contact-errors">
            {{ form.errors | default_errors }}
          </div>
        {%- endif -%}

        <div class="contact-grid">
          <label class="field">
            <span class="field__label">Name</span>
            <input type="text" name="contact[name]" value="{{ form.name }}" autocomplete="name">
          </label>
          <label class="field">
            <span class="field__label">E-Mail *</span>
            <input type="email" name="contact[email]" value="{{ form.email }}" autocomplete="email" required>
          </label>
          <label class="field">
            <span class="field__label">Telefon</span>
            <input type="tel" name="contact[Telefon]" autocomplete="tel">
          </label>
          <label class="field">
            <span class="field__label">Art des Stücks</span>
            <select name="contact[Art des Stücks]">
              <option value="Ring">Ring</option>
              <option value="Siegelring">Siegelring</option>
              <option value="Kette / Anhänger">Kette / Anhänger</option>
              <option value="Ohrschmuck">Ohrschmuck</option>
              <option value="Ehering / Verlobung">Ehering / Verlobung</option>
              <option value="Armband">Armband</option>
              <option value="Unikat / Sonstiges">Unikat / Sonstiges</option>
            </select>
          </label>
          <label class="field">
            <span class="field__label">Budget (optional)</span>
            <input type="text" name="contact[Budget]" placeholder="z. B. 500–1.000 €">
          </label>
          <label class="field field--full">
            <span class="field__label">Deine Idee *</span>
            <textarea name="contact[body]" rows="6" required>{{ form.body }}</textarea>
          </label>
        </div>

        <div class="contact-actions">
          <button type="submit" class="btn btn--solid">{{ section.settings.button_label }}</button>
          {%- if section.settings.note != blank -%}
            <p class="contact-note">{{ section.settings.note }}</p>
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endform -%}
  </div>
</section>

<style>
  .contact-form {
    margin-top: var(--space-lg);
  }
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-lg) var(--space-md);
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .field--full {
    grid-column: 1 / -1;
  }
  .field__label {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    color: var(--color-text-muted);
  }
  .field input,
  .field select,
  .field textarea {
    width: 100%;
    background: transparent;
    border: 0;
    border-bottom: 1px solid var(--color-hairline-strong);
    color: var(--color-text);
    font: inherit;
    font-size: 1rem;
    padding: 0.55rem 0;
    border-radius: 0;
  }
  .field textarea {
    resize: vertical;
    min-height: 7rem;
  }
  .field input:focus,
  .field select:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--color-text);
  }
  .contact-actions {
    margin-top: var(--space-xl);
    display: flex;
    align-items: center;
    gap: var(--space-md);
    flex-wrap: wrap;
  }
  .contact-note {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    margin: 0;
  }
  .contact-success {
    border: 1px solid var(--color-hairline-strong);
    border-radius: var(--radius);
    padding: var(--space-lg);
    text-align: center;
    font-size: 1.05rem;
  }
  .contact-errors {
    margin-bottom: var(--space-lg);
    color: #b0301c;
    font-size: 0.9rem;
  }
  @media (max-width: 749px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

{% schema %}
{
  "name": "Kontakt / Anfrage",
  "settings": [
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "Maßanfertigung auf Anfrage"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Erzähl uns deine Idee"
    },
    {
      "type": "textarea",
      "id": "intro",
      "label": "Einleitung",
      "default": "Ob Siegelring, Kette oder Ehering — schick uns deine Vorstellung, und wir melden uns mit Skizze und Angebot. Unverbindlich."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Anfrage senden"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Hinweis neben Button",
      "default": "Wir antworten innerhalb von 1–2 Werktagen."
    },
    {
      "type": "textarea",
      "id": "success_message",
      "label": "Danke-Nachricht",
      "default": "Danke für deine Anfrage! Wir melden uns in Kürze bei dir."
    }
  ]
}
{% endschema %}
