<section class="section scheme-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="editorial{% if section.settings.layout == 'reverse' %} editorial--reverse{% endif %}">
      <div class="editorial__media reveal">
        {% render 'responsive-image',
          image: section.settings.image,
          fallback: 'klunker-atelier.png',
          alt: section.settings.heading,
          loading: 'lazy' %}
      </div>

      <div class="editorial__content reveal" style="--reveal-delay: 0.12s;">
        {%- if section.settings.overline != blank -%}
          <span class="overline">{{ section.settings.overline }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="h2 editorial__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="editorial__text rte">{{ section.settings.text }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ol class="bespoke__steps">
            {%- for block in section.blocks -%}
              <li class="bespoke__step" {{ block.shopify_attributes }}>
                <span class="bespoke__num">{{ forloop.index | prepend: '0' }}</span>
                <div>
                  <h3 class="bespoke__step-title">{{ block.settings.title }}</h3>
                  {%- if block.settings.text != blank -%}
                    <p class="bespoke__step-text">{{ block.settings.text }}</p>
                  {%- endif -%}
                </div>
              </li>
            {%- endfor -%}
          </ol>
        {%- endif -%}

        {%- if section.settings.button_label != blank -%}
          <div class="editorial__actions">
            <a
              href="{{ section.settings.button_link | default: '#' }}"
              class="btn{% if section.settings.color_scheme == 'black' %}{% else %} btn--solid{% endif %}"
            >
              {{ section.settings.button_label }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .bespoke__steps {
    margin-top: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }
  .bespoke__step {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: var(--space-md);
    align-items: baseline;
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-hairline);
  }
  .bespoke__num {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    color: var(--color-accent);
    line-height: 1;
  }
  .bespoke__step-title {
    font-family: var(--font-body);
    font-size: 0.82rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }
  .bespoke__step-text {
    margin: 0.4rem 0 0;
    font-size: 0.92rem;
    color: var(--color-text-muted);
  }
</style>

{% schema %}
{
  "name": "Maßanfertigung",
  "tag": "section",
  "max_blocks": 4,
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild",
      "info": "Ohne Bild wird das Atelier-Motiv verwendet."
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Bildposition",
      "options": [
        { "value": "normal", "label": "Bild links" },
        { "value": "reverse", "label": "Bild rechts" }
      ],
      "default": "reverse"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "Maßanfertigung auf Anfrage"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Dein Entwurf, in Gold gegossen."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Ob Siegelring, Kette oder Ehering — wir fertigen jedes Stück nach deinem Entwurf. Für jede:n, ohne Kompromisse. Erzähl uns deine Idee, und wir begleiten dich vom ersten Entwurf bis zum fertigen Schmuck.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Anfrage stellen"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Farbschema",
      "options": [
        { "value": "white", "label": "Reinweiß" },
        { "value": "offwhite", "label": "Off-White" },
        { "value": "black", "label": "Tiefschwarz" }
      ],
      "default": "white"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Schritt",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Anfrage"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Erzähl uns deine Idee — unverbindlich."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Maßanfertigung",
      "blocks": [
        { "type": "step", "settings": { "title": "Anfrage", "text": "Erzähl uns deine Idee — unverbindlich." } },
        { "type": "step", "settings": { "title": "Entwurf", "text": "Wir gestalten Skizze und Angebot für dein Unikat." } },
        { "type": "step", "settings": { "title": "Anfertigung", "text": "Handgefertigt in 18 Karat Gold, nur für dich." } }
      ]
    }
  ]
}
{% endschema %}
