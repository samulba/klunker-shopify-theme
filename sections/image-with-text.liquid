<section class="section scheme-{{ section.settings.color_scheme }}">
  <div class="page-width">
    <div class="editorial{% if section.settings.layout == 'reverse' %} editorial--reverse{% endif %}">
      <div class="editorial__media reveal">
        {% render 'responsive-image',
          image: section.settings.image,
          fallback: section.settings.fallback_image,
          alt: section.settings.heading,
          loading: 'lazy' %}
      </div>

      <div class="editorial__content reveal" style="--reveal-delay: 0.12s;">
        {%- if section.settings.overline != blank -%}
          <span class="overline">{{ section.settings.overline }}</span>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="h2 editorial__title">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.text != blank -%}
          <div class="editorial__text rte">{{ section.settings.text }}</div>
        {%- endif -%}
        {%- if section.settings.button_label != blank -%}
          <div class="editorial__actions">
            <a href="{{ section.settings.button_link | default: '#' }}" class="btn btn--ghost">
              {{ section.settings.button_label }}
            </a>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Bild mit Text",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    },
    {
      "type": "select",
      "id": "fallback_image",
      "label": "Fallback-Motiv (ohne eigenes Bild)",
      "options": [
        { "value": "klunker-bangles.png", "label": "Armreife auf Stein" },
        { "value": "klunker-portrait.png", "label": "Porträt" },
        { "value": "klunker-atelier.png", "label": "Atelier / Etui" },
        { "value": "klunker-hero.png", "label": "Halskette auf Stein" }
      ],
      "default": "klunker-bangles.png"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Bildposition",
      "options": [
        { "value": "normal", "label": "Bild links" },
        { "value": "reverse", "label": "Bild rechts" }
      ],
      "default": "normal"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "Eyebrow",
      "default": "Material & Handwerk"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Leise. Echt. Für immer."
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Wir arbeiten ausschließlich mit massivem 18-Karat-Gold und ausgewählten Diamanten. Jedes Stück wird von Hand gefertigt — für Schmuck, der ein Leben lang getragen und weitergegeben wird.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Unsere Philosophie"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button-Link"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "label": "Farbschema",
      "options": [
        { "value": "white", "label": "Reinweiß" },
        { "value": "offwhite", "label": "Off-White" },
        { "value": "black", "label": "Tiefschwarz" }
      ],
      "default": "offwhite"
    }
  ],
  "presets": [
    {
      "name": "Bild mit Text"
    }
  ]
}
{% endschema %}
