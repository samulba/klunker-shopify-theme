<section class="hero hero--on-image" style="--hero-height: 100vh; --hero-overlay: 0.5;">
  <div class="hero__media">
    {% render 'responsive-image',
      image: section.settings.image,
      fallback: 'klunker-ring-dark.png',
      alt: shop.name,
      loading: 'eager' %}
  </div>
  <div class="hero__overlay"></div>

  <div class="hero__inner page-width">
    <div class="hero__content hero__content--center">
      {%- if section.settings.eyebrow != blank -%}
        <span class="overline">{{ section.settings.eyebrow }}</span>
      {%- endif -%}

      <h1 class="hero__title" style="font-size: clamp(2.6rem, 7vw, 5.5rem);">{{ shop.name }}</h1>

      {%- if section.settings.text != blank -%}
        <div class="hero__text" style="margin-inline: auto;">{{ section.settings.text }}</div>
      {%- endif -%}

      <div class="password-form">
        {%- form 'storefront_password' -%}
          {%- if form.errors -%}
            <p class="password-error">
              {{ form.errors.translated_fields.password | capitalize }} {{ form.errors.messages.password }}
            </p>
          {%- endif -%}
          <div class="password-input">
            <input
              type="password"
              name="password"
              placeholder="{{ section.settings.placeholder | escape }}"
              aria-label="{{ section.settings.placeholder | escape }}"
              required
            >
            <button type="submit" class="btn">{{ section.settings.button_label }}</button>
          </div>
        {%- endform -%}
        <p class="password-note">{{ section.settings.note }}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .password-form {
    margin-top: var(--space-xl);
    max-width: 30rem;
    margin-inline: auto;
  }
  .password-input {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    border-bottom: 1px solid rgba(255, 255, 255, 0.45);
    padding-bottom: 0.6rem;
  }
  .password-input input {
    flex: 1;
    background: transparent;
    border: 0;
    color: #fff;
    font: inherit;
    font-size: 1rem;
    padding: 0.4rem 0;
  }
  .password-input input::placeholder {
    color: rgba(255, 255, 255, 0.6);
  }
  .password-input input:focus {
    outline: none;
  }
  .password-error {
    margin-bottom: var(--space-sm);
    font-size: 0.85rem;
    color: #f1c9c0;
  }
  .password-note {
    margin-top: var(--space-md);
    font-size: 0.75rem;
    letter-spacing: var(--tracking-wide);
    color: rgba(255, 255, 255, 0.6);
  }
</style>

{% schema %}
{
  "name": "Passwort",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hintergrundbild",
      "info": "Ohne Bild wird das dunkle Hero-Motiv verwendet."
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Bald erhältlich"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Handgefertigter Custom-Schmuck aus Berlin. Wir öffnen bald.</p>"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Eingabe-Platzhalter",
      "default": "Passwort"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button-Text",
      "default": "Eintreten"
    },
    {
      "type": "text",
      "id": "note",
      "label": "Hinweis unter dem Formular",
      "default": "Nur mit Passwort zugänglich."
    }
  ]
}
{% endschema %}
